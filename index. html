<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>رادیو زنده (پل گیت‌هاب)</title>
    <style>
        body { background: #1a1a1a; color: white; text-align: center; font-family: Tahoma; padding-top: 50px; }
        .status { color: #00ff00; margin-bottom: 20px; }
    </style>
</head>
<body>
    <h2>پخش زنده اینترنشنال (نسخه اینترنت ملی)</h2>
    <div class="status" id="status">در حال دریافت آخرین قطعه...</div>
    <audio id="player" controls autoplay>
        <source src="live_radio.mp3" type="audio/mpeg">
    </audio>
    <script>
        const player = document.getElementById('player');
        player.onended = function() {
            document.getElementById('status').innerText = 'در حال به‌روزرسانی قطعه جدید...';
            setTimeout(() => {
                player.src = "live_radio.mp3?t=" + str(new Date().getTime()); // جلوگیری از کش شدن
                player.play();
                document.getElementById('status').innerText = 'در حال پخش زنده...';
            }, 5000);
        };
    </script>
</body>
</html>
